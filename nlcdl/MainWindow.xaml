<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:nlcdl"
        xmlns:Wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf" x:Class="nlcdl.MainWindow"
        mc:Ignorable="d"
        Title="国图下载器" Height="450" Width="1000">
    <Grid>
        <TextBox x:Name="URLBox" TextWrapping="Wrap" Text="初始化组件..." VerticalAlignment="Top" Height="32" KeyDown="URLBox_KeyDown"/>

        <Wpf:WebView2 x:Name="WebView" Margin="0,32,200,20" IsEnabled="False"/>
        <Label x:Name="Status" Content="等待可捕获文件..." VerticalAlignment="Bottom" Height="20" Margin="0,0,200,0" />
        <Grid HorizontalAlignment="Right" Margin="0,32,0,0"  Width="200">
            <Button x:Name="PreviewBtn" Content="预览" Margin="10,0,0,10" VerticalAlignment="Bottom" Width="60" IsEnabled="False" Click="PreviewBtn_Click"/>
            <Button x:Name="SaveBtn" Content="保存" Margin="0,0,0,10" VerticalAlignment="Bottom" Width="60" IsEnabled="False" HorizontalAlignment="Center" Click="SaveBtn_Click"/>
            <Button x:Name="DropBtn" Content="放弃" Margin="130,0,0,10" VerticalAlignment="Bottom" Width="60" IsEnabled="False" Click="DropBtn_Click"/>
        </Grid>

    </Grid>
</Window>
